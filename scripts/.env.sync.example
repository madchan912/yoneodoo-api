# ---------------------------------------------------------------------------
# sync_prod_to_local_db.py — 운영(SOURCE) → 로컬(TARGET) 전용
# ---------------------------------------------------------------------------
# 사용법: 이 파일을 복사해 scripts/.env.sync 로 저장한 뒤 값을 채운다.
#         scripts/.env.sync 는 Git에 올리지 않는다.
#
# Neon / 운영 PostgreSQL (읽기 전용 dump)
SYNC_SOURCE_HOST=ep-xxxxx.region.aws.neon.tech
SYNC_SOURCE_PORT=5432
SYNC_SOURCE_USER=neondb_owner
SYNC_SOURCE_PASSWORD=
SYNC_SOURCE_DB=neondb

# Neon SSL (기본 require). 내부망 전용이면 disable 등으로 변경.
# SYNC_SOURCE_SSLMODE=require

# 로컬 Docker PostgreSQL (덮어쓰기 대상 — 반드시 localhost 계열)
SYNC_TARGET_HOST=127.0.0.1
SYNC_TARGET_PORT=5433
SYNC_TARGET_USER=root
SYNC_TARGET_PASSWORD=
SYNC_TARGET_DB=yoneodoo
