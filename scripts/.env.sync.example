# ---------------------------------------------------------------------------
# sync_prod_to_local_db.py — 운영(SOURCE) → 로컬(TARGET) 전용
# ---------------------------------------------------------------------------
# 사용법: 이 파일을 복사해 scripts/.env.sync 로 저장한 뒤 값을 채운다.
#         scripts/.env.sync 는 Git에 올리지 않는다.
#
# pg_dump / pg_restore 는 Docker 컨테이너에서 실행하므로 로컬 설치 불필요.
# Docker Desktop(또는 Docker Engine)만 있으면 된다.

# ── SOURCE: 운영 PostgreSQL (RDS 등) ──────────────────────────────────────
SYNC_SOURCE_HOST=yoneodoo-db.xxxxxxxxxx.ap-northeast-2.rds.amazonaws.com
SYNC_SOURCE_PORT=5432
SYNC_SOURCE_USER=postgres
SYNC_SOURCE_PASSWORD=
SYNC_SOURCE_DB=yoneodoo

# SOURCE SSL (기본 require). 내부망 전용이면 disable 로 변경.
# SYNC_SOURCE_SSLMODE=require

# ── TARGET: 로컬 Docker PostgreSQL (덮어쓰기 대상) ────────────────────────
# TARGET_HOST 는 검증용. 로컬 주소(localhost / 127.x.x.x / host.docker.internal)만 허용.
SYNC_TARGET_HOST=localhost
SYNC_TARGET_USER=postgres
SYNC_TARGET_PASSWORD=
SYNC_TARGET_DB=yoneodoo

# ── Docker 설정 ───────────────────────────────────────────────────────────
# 로컬에서 실행 중인 PostgreSQL 컨테이너 이름.
# 비워두면 'docker ps' 에서 postgres 이미지를 자동 탐지한다.
# SYNC_DOCKER_CONTAINER=yoneodoo-postgres

# pg_dump 전용 임시 컨테이너에 사용할 이미지 (로컬에 없으면 자동 pull).
# 운영 DB 버전과 맞추는 것을 권장한다.
# SYNC_PG_IMAGE=postgres:16
